# Database
DATABASE_URL=postgresql://foodfleet:foodfleet_secret@localhost:5432/foodfleet
POSTGRES_PASSWORD=foodfleet_secret

# Auth
SESSION_SECRET=your_super_secret_key_here

# Razorpay (Test Mode) — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Gmail SMTP)
# Use an App Password — see https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Frontend base URL (used in email links)
FRONTEND_URL=http://localhost
