FROM node:24-alpine AS builder
WORKDIR /app

RUN npm install -g pnpm

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY lib/api-spec/package.json ./lib/api-spec/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY artifacts/food-delivery/package.json ./artifacts/food-delivery/

RUN pnpm install --frozen-lockfile

COPY lib/ ./lib/
COPY artifacts/food-delivery/ ./artifacts/food-delivery/
COPY tsconfig.base.json tsconfig.json ./

RUN pnpm run typecheck:libs
RUN cd artifacts/food-delivery && pnpm run build

FROM nginx:alpine AS runner
COPY --from=builder /app/artifacts/food-delivery/dist /usr/share/nginx/html

COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
